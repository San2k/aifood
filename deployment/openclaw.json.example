  },
  "update": {
    "channel": "stable"
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.0-flash-exp",
        "fallbacks": ["google/gemini-2.0-flash"]
