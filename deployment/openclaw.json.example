      "mode": "token"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "aifood": {
        "enabled": true,
        "config": {
          "fatsecretClientId": "REPLACE_WITH_YOUR_FATSECRET_CLIENT_ID",
          "fatsecretClientSecret": "REPLACE_WITH_YOUR_FATSECRET_CLIENT_SECRET",
          "databaseUrl": "postgresql://aifood:YOUR_DB_PASSWORD@localhost:5433/aifood"
        }
      }
    },
    "installs": {
      "aifood": {
        "source": "path",
        "sourcePath": "/opt/aifood/aifood-plugin",
