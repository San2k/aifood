      "models": {
        "google/gemini-2.0-flash-exp": {},
        "google/gemini-2.0-flash": {}
      },
      "workspace": "/root/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "hooks": {
    "enabled": true,
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": false,
    "internal": {
      "enabled": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "botToken": "REPLACE_WITH_YOUR_BOT_TOKEN",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "allowFrom": [
        "*"
      ]
