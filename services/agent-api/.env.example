# Database
DATABASE_URL=postgresql+asyncpg://aifood:aifood_secure_password_2024@localhost:5433/aifood

# Redis
REDIS_URL=redis://localhost:6379/0

# OCR Service
OCR_SERVICE_URL=http://localhost:8001

# Gemini Vision API (required for fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Image Processing
IMAGE_TARGET_SIZE=1400
TEMP_UPLOAD_DIR=/tmp/aifood/uploads

# OCR Quality Thresholds
OCR_CONFIDENCE_THRESHOLD=0.75
MIN_NUTRITION_MARKERS=2
